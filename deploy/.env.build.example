# Optional build-time mirrors (copy to .env.build or export before docker-compose build)
# Defaults in docker-compose.yml already target China; override only if needed.

# Debian apt mirror (backend image)
DOCKER_APT_MIRROR=mirrors.aliyun.com
# Alternatives: mirrors.tuna.tsinghua.edu.cn, mirrors.ustc.edu.cn

# pip index (backend image)
DOCKER_PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# Alternative: https://mirrors.aliyun.com/pypi/simple/

# npm registry (frontend image)
DOCKER_NPM_REGISTRY=https://registry.npmmirror.com
