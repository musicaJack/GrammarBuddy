# 阿里云百炼 API Key（国内北京地域）
# 复制本文件为 .env 并填入你的 Key：copy .env.example .env
# 不要加引号；若从网页复制，请检查首尾没有弯引号 ' '
DASHSCOPE_API_KEY=sk-your-api-key-here

# 国内（北京）OpenAI 兼容端点
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_HTTP_API_URL=https://dashscope.aliyuncs.com/api/v1

# 语法纠错 LLM
QWEN_MODEL=qwen3.7-plus
QWEN_ENABLE_THINKING=false

# 语音合成 TTS
QWEN_TTS_MODEL=qwen3-tts-flash
QWEN_TTS_VOICE=Cherry
QWEN_TTS_LANGUAGE=English

# 语音识别 ASR（录音上传至千问识别，国内可用）
QWEN_ASR_MODEL=qwen3-asr-flash
QWEN_ASR_LANGUAGE=en

# 新闻主题（可选 NewsAPI；未配置则使用 RSS / 内置示例）
NEWS_API_KEY=
NEWS_MIN_TURNS=3

# 新闻 TTS 分段（按自然段/句切分，并行预合成）
TTS_SEGMENT_MAX_WORDS=80
TTS_MAX_CONCURRENT=3

# 服务
HOST=0.0.0.0
PORT=8000
# 本地开发
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# 生产（子路径部署）示例：
# CORS_ORIGINS=https://www.beingdigital.cn,https://beingdigital.cn
